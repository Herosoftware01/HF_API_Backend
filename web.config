<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Disable WebDAV -->
    <modules runAllManagedModulesForAllRequests="false">
      <remove name="WebDAVModule" />
    </modules>

    <!-- SECURITY -->
    <security>
      <requestFiltering>
        <verbs allowUnlisted="true">
          <add verb="PUT" allowed="true" />
          <add verb="DELETE" allowed="true" />
          <add verb="PATCH" allowed="true" />
          <add verb="OPTIONS" allowed="true" />
        </verbs>
      </requestFiltering>
      <authentication>
        <anonymousAuthentication enabled="true" />
        <windowsAuthentication enabled="false" />
      </authentication>
    </security>

    <!-- HANDLERS -->
    <handlers>
      <remove name="WebDAV" />

      <!-- Django via wfastcgi -->
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="D:\PRODUCTION_SOFTWEARE\backend\ENV\Scripts\python.exe|D:\PRODUCTION_SOFTWEARE\backend\ENV\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />

      <!-- Static files served by IIS -->
      <add name="StaticFilesHandler"
           path="*"
           verb="*"
           modules="StaticFileModule"
           resourceType="File"
           requireAccess="Read" />
    </handlers>

    <!-- STATIC CONTENT MIME TYPES -->
    <staticContent>
      <remove fileExtension=".css" />
      <remove fileExtension=".js" />
      <remove fileExtension=".png" />
      <remove fileExtension=".jpg" />
      <remove fileExtension=".gif" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <mimeMap fileExtension=".png" mimeType="image/png" />
      <mimeMap fileExtension=".jpg" mimeType="image/jpeg" />
      <mimeMap fileExtension=".gif" mimeType="image/gif" />
    </staticContent>

    <!-- DISABLE DIRECTORY BROWSING -->
    <directoryBrowse enabled="false" />

    <!-- REMOVE DEFAULT DOCUMENTS -->
    <defaultDocument>
      <files>
        <clear />
      </files>
    </defaultDocument>

    <!-- URL REWRITE -->
    <rewrite>
      <rules>
        <!-- Only rewrite requests NOT starting with /static/ or /media/ to Django -->
        <rule name="DjangoApp" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_URI}" pattern="^/static/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/media/" negate="true" />
          </conditions>
          <action type="Rewrite" url="wfastcgi.py" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>

  <!-- DJANGO SETTINGS -->
  <appSettings>
    <add key="WSGI_HANDLER" value="backend.wsgi.application" />
    <add key="DJANGO_SETTINGS_MODULE" value="backend.settings" />
    <add key="PYTHONPATH" value="D:\PRODUCTION_SOFTWEARE\backend" />
    <add key="WSGI_LOG" value="D:\PRODUCTION_SOFTWEARE\back_logs\wfastcgi.log" />
  </appSettings>

</configuration>